VITE_SERVER_URL=https://your-litecord-server.onrender.com

# TURN relay — required for cross-ISP / cross-network WebRTC (symmetric NAT traversal)
# Free tier (20 GB/month, no credit card): https://www.metered.ca/tools/openrelay/
VITE_TURN_URL=turn:openrelay.metered.ca:80,turns:openrelay.metered.ca:443,turn:openrelay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your_metered_username
VITE_TURN_CREDENTIAL=your_metered_password
